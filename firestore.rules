rules_version = '2';

// ★DDoS・不正アクセス・課金爆発への防御ルール★
// 方針:
//  - 認証済み（匿名認証でOK）ユーザーだけがアクセスできる
//  - アクセスできるのは対戦ルーム(rooms)だけ。他のパスは全面禁止
//  - ルームのサイズ（プレイヤー数・デッキ・場札）に上限を設けて肥大化を防ぐ
//  - クライアントからの削除は禁止（サーバー/TTLで管理）
// さらに Firebase コンソールで App Check を「強制」にすると、
// 本物のアプリ以外からのアクセスをほぼ完全に遮断できる（SECURITY.md参照）。
service cloud.firestore {
  match /databases/{database}/documents {

    // オンライン対戦ルーム
    match /rooms/{roomId} {
      // 妥当なサイズかを検証するヘルパ（肥大化・スパム書き込み対策）
      function sane(data) {
        return data.players is list
          && data.players.size() <= 8            // 1部屋 最大8人
          && (!('deck' in data) || data.deck.size() <= 80)        // 12種×5枚=60 + 余裕
          && (!('fieldCards' in data) || data.fieldCards.size() <= 80)
          && (!('seenImages' in data) || data.seenImages.size() <= 40)
          && (!('imageUrls' in data) || data.imageUrls.size() <= 20);
      }

      allow read: if request.auth != null;
      allow create: if request.auth != null && sane(request.resource.data);
      allow update: if request.auth != null && sane(request.resource.data);
      allow delete: if false; // クライアントからの削除は不可
    }

    // ランダムマッチのランキング（レーティング）
    match /rankings/{uid} {
      // 全員が閲覧可能（リーダーボード表示）
      allow read: if request.auth != null;
      // 書き込みは本人のドキュメントのみ。値の妥当性を厳格に検証する。
      allow write: if request.auth != null
        && uid == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 16
        && request.resource.data.rating is int
        && request.resource.data.rating >= 0
        && request.resource.data.rating <= 100000
        && request.resource.data.wins is int
        && request.resource.data.losses is int
        && request.resource.data.wins >= 0
        && request.resource.data.losses >= 0
        && (
          // 新規作成時（既存ドキュメントなし）
          !exists(/databases/$(database)/documents/rankings/$(uid))
          // または既存からの変化が妥当（1回のレート変動は±40、勝敗は+1まで）
          //   これにより「レートを一気に99999にする」等の不正を防ぐ
          || (
            request.resource.data.rating >= resource.data.rating - 40
            && request.resource.data.rating <= resource.data.rating + 40
            && request.resource.data.wins >= resource.data.wins
            && request.resource.data.wins <= resource.data.wins + 1
            && request.resource.data.losses >= resource.data.losses
            && request.resource.data.losses <= resource.data.losses + 1
          )
        );
      allow delete: if false;
    }

    // 上記以外のあらゆるドキュメントへのアクセスを全面的に禁止
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
